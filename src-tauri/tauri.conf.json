{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Weather Overlay",
  "version": "0.1.0",
  "identifier": "com.aelia.weather-overlay",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "overlay",
        "title": "Weather Overlay",
        "url": "overlay.html",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "fullscreen": false,
        "maximized": true,
        "resizable": false,
        "shadow": false,
        "visible": true,
        "focus": false
      },
      {
        "label": "settings",
        "title": "Weather Overlay Settings",
        "url": "settings.html",
        "width": 420,
        "height": 720,
        "minHeight": 480,
        "visible": true,
        "center": true,
        "decorations": true,
        "resizable": true,
        "transparent": true,
        "shadow": false
      },
      {
        "label": "widget",
        "title": "Weather",
        "url": "widget.html",
        "width": 400,
        "height": 228,
        "minWidth": 320,
        "minHeight": 140,
        "visible": false,
        "center": false,
        "decorations": false,
        "resizable": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
